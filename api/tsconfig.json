{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": { "@shared/*": ["../../shared/*"] }
  },
  "include": ["src"],
  "exclude": ["tests", "node_modules", "dist"]
}
