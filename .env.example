# AtomFortune Environment Variables
# Copy this file to .env and adjust as needed.
# All variables have sensible defaults — most users don't need to change anything.

# ── API Server ───────────────────────────────────────────────────────────────

# Path to the SQLite database file
DATABASE_PATH=./atomfortune.db

# Base currency for net worth calculations
# Supported: USD, TWD, JPY, EUR, GBP, CNY, HKD, KRW, SGD, AUD, CAD, CHF, MXN, INR, BRL, RUB, TRY
BASE_CURRENCY=TWD

# Cron expression for the daily snapshot job (default: 10pm every day)
SNAPSHOT_SCHEDULE=0 22 * * *

# Port for the API server
PORT=8000

# ── Web Frontend ─────────────────────────────────────────────────────────────

# URL of the API server (used by Next.js server-side rendering)
API_ORIGIN=http://localhost:8000

# URL of the web frontend (used by the Cloudflare Tunnel feature)
WEB_ORIGIN=http://localhost:3000
